    <node id="Standard Committ ee">
      <data key="d0">Standard Committ ee</data>
      <data key="d1">organization</data>
      <data key="d2">The Standard Committee is responsible for approving and revising standards like ASME B16.5.</data>
      <data key="d3">chunk-545818ef44ac301232f6e8003ced593b</data>
      <data key="d4">unknown_source</data>
