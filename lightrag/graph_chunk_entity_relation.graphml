    <node id="a">
      <data key="d0">a</data>
      <data key="d1">concept</data>
      <data key="d2">a is zero, except where the small female face is on the end of the pipe, then it is 5 mm (0.19 in.).</data>
      <data key="d3">chunk-e8804956c092c1734b0447ce75691b29</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
