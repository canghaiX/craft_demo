    <node id="G">
      <data key="d0">G</data>
      <data key="d1">concept</data>
      <data key="d2">G is the gasket thickness for raised face, male and female tongue and groove flanges.</data>
      <data key="d3">chunk-e8804956c092c1734b0447ce75691b29</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
