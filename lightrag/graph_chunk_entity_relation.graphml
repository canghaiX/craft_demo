      <data key="d0">Socket Welding Connections</data>
      <data key="d1">concept</data>
      <data key="d2">Socket Welding Connections involve attaching components to pipe fittings through sockets, requiring adequate wall thickness or reinforcement.</data>
      <data key="d3">chunk-c551c98db1e7353686af155387c310fd</data>
