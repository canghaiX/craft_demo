    <node id="Minimum Diameter">
      <data key="d0">Minimum Diameter</data>
      <data key="d1">concept</data>
      <data key="d2">Minimum Diameter is the smallest allowable diameter in a flange.&lt;SEP&gt;Minimum diameter is the smallest diameter of the flange.</data>
      <data key="d3">chunk-de39ca8c7c360d8542b6e7b848f32671&lt;SEP&gt;chunk-9dc638f0d9855d44e84fb84b1e17f97e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329043</data>
      <data key="d6" />
    </node>
    <node id="Minimum Thread Length">
      <data key="d0">Minimum Thread Length</data>
      <data key="d1">concept</data>
      <data key="d2">Minimum thread length is the shortest length of the thread on the flange.</data>
      <data key="d3">chunk-de39ca8c7c360d8542b6e7b848f32671</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329043</data>
      <data key="d6" />
    </node>
    <node id="Minimum Radius">
      <data key="d0">Minimum Radius</data>
      <data key="d1">concept</data>
      <data key="d2">Minimum radius is the smallest radius of the minimum corner bore.</data>
      <data key="d3">chunk-de39ca8c7c360d8542b6e7b848f32671</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329043</data>
      <data key="d6" />
    </node>
