    <node id="ANSI">
      <data key="d0">ANSI</data>
      <data key="d1">organization</data>
      <data key="d2">ANSI (American National Standards Institute) approves American National Standards, including ASME B16.5.</data>
      <data key="d3">chunk-545818ef44ac301232f6e8003ced593b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255080</data>
      <data key="d6" />
