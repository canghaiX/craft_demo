    <node id="Threaded Bore">
      <data key="d0">Threaded Bore</data>
      <data key="d1">artifact</data>
      <data key="d2">Threaded Bore is the bore that contains threads in a flange.&lt;SEP&gt;Threaded bore is the bore in the flange that is threaded to accept a bolt.</data>
      <data key="d3">chunk-de39ca8c7c360d8542b6e7b848f32671&lt;SEP&gt;chunk-9dc638f0d9855d44e84fb84b1e17f97e</data>
