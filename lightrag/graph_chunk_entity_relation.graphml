    <node id="t1">
      <data key="d0">t1</data>
      <data key="d1">data</data>
      <data key="d2">t1 is a variable representing a thickness in the context of welding neck flanges.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
    </node>
    <node id="t2">
      <data key="d0">t2</data>
      <data key="d1">data</data>
      <data key="d2">t2 is a variable representing another thickness in the context of welding neck flanges.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
    </node>
    <node id="tD">
      <data key="d0">tD</data>
      <data key="d1">data</data>
      <data key="d2">tD is a variable representing the additional thickness for welding to higher strength pipe.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
    </node>
    <node id="0.5t">
      <data key="d0">0.5t</data>
      <data key="d1">data</data>
      <data key="d2">0.5t is a threshold value for the sum of t1 and t2.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
    </node>
    <node id="t1 + t2">
      <data key="d0">t1 + t2</data>
      <data key="d1">data</data>
      <data key="d2">t1 + t2 is the sum of two thickness variables in the context of welding neck flanges.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
    </node>
    <node id="t">
      <data key="d0">t</data>
      <data key="d1">data</data>
      <data key="d2">t is a variable representing the mating wall thickness in the context of welding neck flanges.&lt;SEP&gt;t is a placeholder for data in the table.&lt;SEP&gt;t is the plus tolerance for flange thickness.</data>
