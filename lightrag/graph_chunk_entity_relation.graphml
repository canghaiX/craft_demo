      <data key="d5">1776255059</data>
      <data key="d6" />
    </node>
    <node id="Flange Edge-to-Flange Edge Dimensions">
      <data key="d0">Flange Edge-to-Flange Edge Dimensions</data>
      <data key="d1">concept</data>
      <data key="d2">Flange Edge-to-Flange Edge Dimensions are the distance between the edges of two flanges.</data>
      <data key="d3">chunk-1c16e04b6fef5dddbccafe35258da63d</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255059</data>
      <data key="d6" />
    </node>
    <node id="Center-to-Flange Edge Dimensions">
      <data key="d0">Center-to-Flange Edge Dimensions</data>
      <data key="d1">concept</data>
      <data key="d2">Center-to-Flange Edge Dimensions are the distance from the center of a fitting to the edge of a flange.</data>
