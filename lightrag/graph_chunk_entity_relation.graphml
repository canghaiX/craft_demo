      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329043</data>
      <data key="d6" />
    </node>
    <node id="Lapped Flange">
      <data key="d0">Lapped Flange</data>
      <data key="d1">artifact</data>
      <data key="d2">Lapped Flange is a type of flange described in ASME B16.5-2013.</data>
