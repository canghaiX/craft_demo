      <data key="d6" />
    </node>
    <node id="normalized">
      <data key="d0">normalized</data>
      <data key="d1">process</data>
      <data key="d2">Normalized refers to a heat treatment process where the material is heated to a specific temperature and then cooled slowly to achieve a uniform microstructure.</data>
