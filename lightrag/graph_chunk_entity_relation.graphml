    <node id="Table 14">
      <data key="d0">Table 14</data>
      <data key="d1">content</data>
      <data key="d2">Table 14 provides minimum thread lengths for reducing flanges.&lt;SEP&gt;Table 14 provides dimensions of class 400 flanges.</data>
