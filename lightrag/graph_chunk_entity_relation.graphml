    <node id="1988 Edition">
      <data key="d0">1988 Edition</data>
      <data key="d1">data</data>
      <data key="d2">The 1988 Edition of ASME B16.5 introduced nickel alloy ratings for higher temperatures, clarified flat face flange requirements, and made other minor revisions.</data>
      <data key="d3">chunk-545818ef44ac301232f6e8003ced593b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255080</data>
