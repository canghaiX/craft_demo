    <node id="High Temperature">
      <data key="d0">High Temperature</data>
      <data key="d1">concept</data>
      <data key="d2">High temperature refers to temperatures in the creep range where bolt loads decrease due to relaxation.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Low Temperature">
      <data key="d0">Low Temperature</data>
      <data key="d1">concept</data>
      <data key="d2">Low temperature refers to conditions where materials may lose ductility and fail to resist shock loading.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Joint Leakage">
      <data key="d0">Joint Leakage</data>
      <data key="d1">concept</data>
      <data key="d2">Joint leakage occurs due to forces and moments developed in connected piping or equipment.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Thermal Gradients">
      <data key="d0">Thermal Gradients</data>
      <data key="d1">concept</data>
      <data key="d2">Thermal gradients can lead to decreasing bolt loads in flanged joints.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Bolt Loads">
      <data key="d0">Bolt Loads</data>
      <data key="d1">concept</data>
      <data key="d2">Bolt loads decrease as relaxation of flanges, bolts, and gaskets takes place at high temperatures.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Creep Range">
      <data key="d0">Creep Range</data>
      <data key="d1">concept</data>
      <data key="d2">Creep range is a temperature range where materials exhibit creep deformation.&lt;SEP&gt;The creep range is the temperature range above 370°C (700°F) where materials exhibit creep behavior.&lt;SEP&gt;Creep range is the temperature range over which a material exhibits creep, a time-dependent plastic deformation.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815&lt;SEP&gt;chunk-f7d037c7aa1de140eef228e3b5f72b1a&lt;SEP&gt;chunk-dc67612f135316380b75df378379082b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="Impact Testing">
      <data key="d0">Impact Testing</data>
      <data key="d1">concept</data>
      <data key="d2">Impact testing is required for some materials at low temperatures to ensure safe resistance to shock loading.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="System Hydrostatic Testing">
      <data key="d0">System Hydrostatic Testing</data>
      <data key="d1">concept</data>
      <data key="d2">System hydrostatic testing is performed at a pressure of 1.5 times the 38°C (100°F) rating.</data>
      <data key="d3">chunk-15d13d8a9cf127681d0ef72c7289a815</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255082</data>
      <data key="d6" />
    </node>
    <node id="ASME B36.10M">
      <data key="d0">ASME B36.10M</data>
      <data key="d1">standard</data>
      <data key="d2">ASME B36.10M is referenced for standard wall pipe dimensions, particularly for bore sizes of pipe.</data>
