    <node id="Table 9">
      <data key="d0">Table 9</data>
      <data key="d1">table</data>
      <data key="d2">Table 9 in Mandatory Appendix II provides minimum wall thickness specifications.&lt;SEP&gt;Table 9 provides minimum thread lengths for reducing flanges.&lt;SEP&gt;Table 9 details the dimensions of Class 150 Flanged Fittings.&lt;SEP&gt;Table 9 provides minimum dimensions for loose flanges.</data>
      <data key="d3">chunk-47d30b91c8304767d9ee5dee433bb6cd&lt;SEP&gt;chunk-57eadb61afc03dbca89ec4177318d30f&lt;SEP&gt;chunk-ab71f5f8294a0ded93d84d65df8a8aeb&lt;SEP&gt;chunk-28281081225db05b8b7d5f11501b022d</data>
