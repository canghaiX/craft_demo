    <node id="Welding Ends (Welding Neck Flanges)">
      <data key="d0">Welding Ends (Welding Neck Flanges)</data>
      <data key="d1">artifact</data>
      <data key="d2">Welding Ends (Welding Neck Flanges) are components used in the fabrication of flanged fittings.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
