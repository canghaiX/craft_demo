    <node id="Reducing Flanges">
      <data key="d0">Reducing Flanges</data>
      <data key="d1">artifact</data>
      <data key="d2">Reducing Flanges are used to reduce the size of pipe connections.&lt;SEP&gt;Reducing Flanges are pipe flanges used to connect pipes of different diameters.</data>
      <data key="d3">chunk-f28c7d4bdd4e434720bb2e0817acb7da&lt;SEP&gt;chunk-7040bbb99f12a42660ed8b6b948c1e9b</data>
