    <node id="American National Standard Locknut Thread (NPSL)">
      <data key="d0">American National Standard Locknut Thread (NPSL)</data>
      <data key="d1">standard</data>
      <data key="d2">American National Standard Locknut Thread (NPSL) is a threading standard used for threaded companion flanges in small male and female joints.</data>
      <data key="d3">chunk-5f3cbee2b8b675333577ec60e28d2c11</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776347057</data>
