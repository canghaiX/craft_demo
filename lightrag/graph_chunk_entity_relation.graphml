    <node id="LSSB">
      <data key="d0">LSSB</data>
      <data key="d1">concept</data>
      <data key="d2">LSSB is a specified stud bolt length (effective thread length, excluding end points).</data>
      <data key="d3">chunk-e8804956c092c1734b0447ce75691b29</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
