    <node id="Tolerances">
      <data key="d0">Tolerances</data>
      <data key="d1">concept</data>
      <data key="d2">Tolerances define acceptable variations in component dimensions.&lt;SEP&gt;Tolerances define acceptable limits of variation in dimensions.&lt;SEP&gt;Tolerances are specified for certain dimensions and are detailed in section 7.</data>
      <data key="d3">chunk-a6697f0fc19ceac7a699746d339338c6&lt;SEP&gt;chunk-1a18d7afa11aad3756a7707e009d78fc&lt;SEP&gt;chunk-57eadb61afc03dbca89ec4177318d30f</data>
