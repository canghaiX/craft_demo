    </node>
    <node id="Threaded Companion Flanges">
      <data key="d0">Threaded Companion Flanges</data>
      <data key="d1">artifact</data>
      <data key="d2">Threaded Companion Flanges are pipe fittings furnished with plain faces and threaded according to the American National Standard Locknut Thread (NPSL) standard.</data>
