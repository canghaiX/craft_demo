    <node id="Permissible but not recommended for prolonged use above 590°C.">
      <data key="d0">Permissible but not recommended for prolonged use above 590°C.</data>
      <data key="d1">note</data>
      <data key="d2">The use of certain materials is permissible but not recommended for temperatures above 590°C.</data>
      <data key="d3">chunk-94e58312a7e84066f13cc4e7ad9465d9</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329041</data>
      <data key="d6" />
    </node>
