    <edge source="Raised Face Flange" target="Minimum Flange Thickness, tf">
      <data key="d7">1.0</data>
      <data key="d8">Raised Face Flanges are regularly furnished with a 7 mm (0.25 in.) raised face in addition to the minimum flange thickness, tf.</data>
      <data key="d9">flange specification,thickness requirement</data>
      <data key="d10">chunk-43e5005d4928be252c7355587c71a1aa</data>
