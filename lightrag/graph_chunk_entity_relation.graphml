    </node>
    <node id="1.5 times the 38°C (100°F) pressure rating">
      <data key="d0">1.5 times the 38°C (100°F) pressure rating</data>
      <data key="d1">data</data>
      <data key="d2">1.5 times the 38°C (100°F) pressure rating is the minimum pressure for the shell pressure test.</data>
      <data key="d3">chunk-37388fa1515f3cf7a8930b2598d5740e</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329034</data>
      <data key="d6" />
