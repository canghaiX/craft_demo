    <node id="Pressure–Temperature Ratings">
      <data key="d0">Pressure–Temperature Ratings</data>
      <data key="d1">concept</data>
      <data key="d2">Pressure–Temperature Ratings describe the operational limits of components.&lt;SEP&gt;Pressure–Temperature Ratings are data points indicating the maximum pressure and temperature limits for specific materials.&lt;SEP&gt;Pressure–Temperature Ratings are specifications for materials used in pipe flanges and fittings.</data>
      <data key="d3">chunk-a6697f0fc19ceac7a699746d339338c6&lt;SEP&gt;chunk-6a55c2f18bc2ea7f90938840b2a7bbb8&lt;SEP&gt;chunk-e0e55f15f4fdc887c0046610b4244415</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329040</data>
      <data key="d6" />
    </node>
