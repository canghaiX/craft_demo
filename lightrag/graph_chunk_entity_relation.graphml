    <node id="Reducing Fittings">
      <data key="d0">Reducing Fittings</data>
      <data key="d1">artifact</data>
      <data key="d2">Reducing fittings are used to connect pipes of different diameters.&lt;SEP&gt;Reducing Fittings are fittings that connect pipes of different diameters, with specific dimensions outlined in the standard.&lt;SEP&gt;Reducing Fittings are fittings that connect pipes of different diameters.&lt;SEP&gt;Reducing fittings are components that reduce the size of pipes or tubes.</data>
      <data key="d3">chunk-1c16e04b6fef5dddbccafe35258da63d&lt;SEP&gt;chunk-4797fefc55d99753aacd5d36c1d642f3&lt;SEP&gt;chunk-168613df3512c6ad1c5f5bdc4c21ec22&lt;SEP&gt;chunk-79385a11135d33465afc630658dca15b</data>
      <data key="d4">unknown_source</data>
      <data key="d5">1776255059</data>
      <data key="d6" />
    </node>
    <node id="Reinforcement">
      <data key="d0">Reinforcement</data>
      <data key="d1">concept</data>
      <data key="d2">Reinforcement involves strengthening certain fittings.</data>
      <data key="d3">chunk-1c16e04b6fef5dddbccafe35258da63d&lt;SEP&gt;chunk-4797fefc55d99753aacd5d36c1d642f3</data>
