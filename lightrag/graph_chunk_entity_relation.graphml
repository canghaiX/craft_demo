    <node id="Table II-10">
      <data key="d0">Table II-10</data>
      <data key="d1">content</data>
      <data key="d2">Table II-10 contains stud bolt length information.&lt;SEP&gt;Table II-10 provides templates for drilling Class 300 flanges, detailing bolt circle diameters and hole sizes.</data>
      <data key="d3">chunk-51676999d6498cdd7ba881a128f7d63f&lt;SEP&gt;chunk-b181980b1dcef22dc859d6b6b9c724e1</data>
