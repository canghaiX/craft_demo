    <node id="Raised Face Male and Female/ Ring">
      <data key="d0">Raised Face Male and Female/ Ring</data>
      <data key="d1">artifact</data>
      <data key="d2">Raised Face Male and Female/ Ring is a type of flange face design.</data>
