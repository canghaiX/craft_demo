      <data key="d0">Minimum Welding Neck Length</data>
      <data key="d1">attribute</data>
      <data key="d2">Minimum Welding Neck Length is a dimension of the flange described in ASME B16.5-2013.</data>
      <data key="d3">chunk-4a2aa51a49817516d8e488a9d7c544a9</data>
      <data key="d4">ASME B16.5-2013.pdf</data>
      <data key="d5">1776329043</data>
      <data key="d6" />
    </node>
    <node id="Socket Welding Flange">
      <data key="d0">Socket Welding Flange</data>
