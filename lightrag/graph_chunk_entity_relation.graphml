    </node>
    <node id="Table II-5">
      <data key="d0">Table II-5</data>
      <data key="d1">content</data>
      <data key="d2">Table II-5 provides dimensions in inch units for flanges and法兰附件.&lt;SEP&gt;Table II-5 contains dimensions of Ring-Joint Facings for different pressure rating classes.&lt;SEP&gt;Table II-5 provides ring joint facing dimensions for flanges.&lt;SEP&gt;Table II-5 in Mandatory Appendix II provides ring joint facing dimensions.</data>
      <data key="d3">chunk-79c64f1efd29986d7f72185f69bc53da&lt;SEP&gt;chunk-2904771c0741938726758dab221ea2fd&lt;SEP&gt;chunk-4c9e213122af67bab4c41acc3eba18e1&lt;SEP&gt;chunk-d7c70c0ed0335f782bec1b3df7c995a5</data>
