    <node id="−20 to 100">
      <data key="d0">−20 to 100</data>
      <data key="d1">range</data>
      <data key="d2">−20 to 100 is a temperature range for pressure ratings.&lt;SEP&gt;−20 to 100 is a temperature range mentioned in the table.&lt;SEP&gt;−20 to 100 is the temperature range for some of the pressure-temperature ratings.</data>
      <data key="d3">chunk-a0109166d44b4066c639726c7a8ccb61&lt;SEP&gt;chunk-ba38e995e9267b01b62ee7faaf352b6b&lt;SEP&gt;chunk-27f045cb711599e1626ae4544de66292</data>
