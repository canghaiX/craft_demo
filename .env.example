OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=
AGENT_MODEL=gpt-4o-mini
ROUTER_MODEL=gpt-4o-mini
LIGHTRAG_LLM_MODEL=gpt-4o-mini
LIGHTRAG_EMBED_MODEL=text-embedding-3-large
